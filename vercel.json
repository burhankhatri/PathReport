{
  "version": 2,
  "framework": null,
  "installCommand": "npm install && cd client && npm install",
  "buildCommand": "cd client && npm run build",
  "outputDirectory": "client/dist",
  "functions": {
    "api/*.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/transcribe", "destination": "/api/transcribe.js" },
    { "source": "/api/generate-report", "destination": "/api/generate-report.js" },
    { "source": "/api/generate-pdf", "destination": "/api/generate-pdf.js" },
    { "source": "/api/reports", "destination": "/api/reports.js" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
